<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SmrtDoodle.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmrtDoodle"
    xmlns:helpers="using:SmrtDoodle.Helpers"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SmrtDoodle">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <MenuBar Grid.Row="0"
                 AutomationProperties.Name="Main menu"
                 AutomationProperties.LandmarkType="Navigation">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="New" Click="New_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="N"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Open..." Click="Open_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="O"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Save" Click="Save_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="S"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Save As..." Click="SaveAs_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control,Shift" Key="S"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Print..." Click="Print_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="P"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem x:Name="InsertIntoDocumentItem" Text="Insert into Document &amp; Close" Click="InsertIntoDocument_Click" Visibility="Collapsed"/>
                <MenuFlyoutItem Text="Exit" Click="Exit_Click"/>
            </MenuBarItem>
            <MenuBarItem Title="Edit">
                <MenuFlyoutItem x:Name="UndoMenuItem" Text="Undo" Click="Undo_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Z"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="RedoMenuItem" Text="Redo" Click="Redo_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Y"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Cut" Click="Cut_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="X"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Copy" Click="Copy_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="C"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Paste" Click="Paste_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="V"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Select All" Click="SelectAll_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="A"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Clear Selection" Click="ClearSelection_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Escape"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Delete Selection" Click="DeleteSelection_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Delete"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Paste as New Image" Click="PasteAsNewImage_Click"/>
                <MenuFlyoutItem Text="Paste From File..." Click="PasteFromFile_Click"/>
            </MenuBarItem>
            <MenuBarItem Title="Image">
                <MenuFlyoutItem Text="Resize..." Click="Resize_Click"/>
                <MenuFlyoutItem Text="Crop" Click="Crop_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Flip Horizontal" Click="FlipH_Click"/>
                <MenuFlyoutItem Text="Flip Vertical" Click="FlipV_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Rotate 90°" Click="Rotate90_Click"/>
                <MenuFlyoutItem Text="Rotate 180°" Click="Rotate180_Click"/>
                <MenuFlyoutItem Text="Rotate 270°" Click="Rotate270_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Invert Colors" Click="InvertColors_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control,Shift" Key="I"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Clear Image" Click="ClearImage_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control,Shift" Key="N"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Canvas Properties..." Click="CanvasProperties_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutSubItem Text="AI Tools (Pro)">
                    <MenuFlyoutItem x:Name="AiRemoveBackground" Text="Remove Background" Click="AiRemoveBackground_Click"
                                    AutomationProperties.Name="AI Remove Background"/>
                    <MenuFlyoutItem x:Name="AiUpscale" Text="Upscale Image..." Click="AiUpscale_Click"
                                    AutomationProperties.Name="AI Upscale Image"/>
                    <MenuFlyoutItem x:Name="AiContentAwareFill" Text="Content-Aware Fill" Click="AiContentAwareFill_Click"
                                    AutomationProperties.Name="AI Content-Aware Fill"/>
                    <MenuFlyoutItem x:Name="AiAutoColorize" Text="Auto-Colorize" Click="AiAutoColorize_Click"
                                    AutomationProperties.Name="AI Auto-Colorize"/>
                    <MenuFlyoutItem x:Name="AiStyleTransfer" Text="Style Transfer..." Click="AiStyleTransfer_Click"
                                    AutomationProperties.Name="AI Style Transfer"/>
                    <MenuFlyoutItem x:Name="AiDenoise" Text="Noise Reduction..." Click="AiDenoise_Click"
                                    AutomationProperties.Name="AI Noise Reduction"/>
                </MenuFlyoutSubItem>
            </MenuBarItem>
            <MenuBarItem Title="View">
                <ToggleMenuFlyoutItem x:Name="ShowGridToggle" Text="Show Grid" Click="ToggleGrid_Click"/>
                <ToggleMenuFlyoutItem x:Name="ShowRulerToggle" Text="Show Ruler" Click="ToggleRuler_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Zoom In" Click="ZoomIn_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Add"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Zoom Out" Click="ZoomOut_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Subtract"/>
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Zoom to Fit" Click="ZoomFit_Click"/>
                <MenuFlyoutItem Text="100%" Click="Zoom100_Click"/>
            </MenuBarItem>
            <MenuBarItem Title="Layers">
                <MenuFlyoutItem Text="Add Layer" Click="AddLayer_Click"/>
                <MenuFlyoutItem Text="Delete Layer" Click="DeleteLayer_Click"/>
                <MenuFlyoutItem Text="Duplicate Layer" Click="DuplicateLayer_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Move Layer Up" Click="MoveLayerUp_Click"/>
                <MenuFlyoutItem Text="Move Layer Down" Click="MoveLayerDown_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Merge Down" Click="MergeDown_Click"/>
                <MenuFlyoutItem Text="Flatten Image" Click="FlattenImage_Click"/>
            </MenuBarItem>
            <MenuBarItem Title="Help">
                <MenuFlyoutItem Text="Keyboard Shortcuts" Click="KeyboardShortcuts_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Settings" Click="Settings_Click"/>
                <MenuFlyoutItem Text="About SmrtDoodle" Click="About_Click"/>
            </MenuBarItem>
        </MenuBar>

        <!-- ═══ RIBBON ═══ -->
        <Border x:Name="RibbonBar" Grid.Row="1"
                AutomationProperties.Name="Toolbar ribbon"
                AutomationProperties.LandmarkType="Custom"
                AutomationProperties.LocalizedLandmarkType="Toolbar"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="4"
                Height="100">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Tools -->
                    <ColumnDefinition Width="Auto"/>  <!-- Sep -->
                    <ColumnDefinition Width="Auto"/>  <!-- Brush -->
                    <ColumnDefinition Width="Auto"/>  <!-- Sep -->
                    <ColumnDefinition Width="Auto"/>  <!-- Shapes -->
                    <ColumnDefinition Width="Auto"/>  <!-- Sep -->
                    <ColumnDefinition Width="Auto"/>  <!-- Selection -->
                    <ColumnDefinition Width="Auto"/>  <!-- Sep -->
                    <ColumnDefinition Width="*"/>     <!-- Colors -->
                    <ColumnDefinition Width="Auto"/>  <!-- Insert -->
                </Grid.ColumnDefinitions>

                <!-- ══ TOOLS ══ -->
                <Grid Grid.Column="0" Padding="4,2,4,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="16"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="1">
                            <ToggleButton x:Name="BtnPencil" Click="Tool_Click" Tag="Pencil" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Pencil (P)" AutomationProperties.Name="Pencil tool" AccessKey="P">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xED63;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnBrush" Click="Tool_Click" Tag="Brush" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Brush (B)" AutomationProperties.Name="Brush tool" AccessKey="B">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE790;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnEraser" Click="Tool_Click" Tag="Eraser" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Eraser (E)" AutomationProperties.Name="Eraser tool" AccessKey="E">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE75C;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnFill" Click="Tool_Click" Tag="Fill" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Fill (G)" AutomationProperties.Name="Fill tool" AccessKey="G">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE771;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnText" Click="Tool_Click" Tag="Text" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Text (T)" AutomationProperties.Name="Text tool" AccessKey="T">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8D2;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnEyedropper" Click="Tool_Click" Tag="Eyedropper" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Color Picker (I)" AutomationProperties.Name="Eyedropper Color Picker tool" AccessKey="I">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEF3C;" FontSize="14"/>
                            </ToggleButton>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="1">
                            <ToggleButton x:Name="BtnLine" Click="Tool_Click" Tag="Line" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Line (L)" AutomationProperties.Name="Line tool" AccessKey="L">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE738;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnCurve" Click="Tool_Click" Tag="Curve" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Curve (C)" AutomationProperties.Name="Curve tool" AccessKey="C">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE746;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnShape" Click="Tool_Click" Tag="Shape" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Shape (H)" AutomationProperties.Name="Shape tool" AccessKey="H">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xF158;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnSelect" Click="Tool_Click" Tag="Selection" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Select (S)" AutomationProperties.Name="Rectangle Selection tool" AccessKey="S">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8B3;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnFreeSelect" Click="Tool_Click" Tag="FreeFormSelection" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Free-form Select (F)" AutomationProperties.Name="Free-form Selection tool" AccessKey="F">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEF20;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnMagnifier" Click="Tool_Click" Tag="Magnifier" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Magnifier (M)" AutomationProperties.Name="Magnifier Zoom tool" AccessKey="M">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE71E;" FontSize="14"/>
                            </ToggleButton>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="1">
                            <ToggleButton x:Name="BtnGradient" Click="Tool_Click" Tag="Gradient" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Gradient (D)" AutomationProperties.Name="Gradient tool" AccessKey="D">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xF0E2;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnBlur" Click="Tool_Click" Tag="Blur" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Blur (U)" AutomationProperties.Name="Blur tool" AccessKey="U">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7B3;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnSharpen" Click="Tool_Click" Tag="Sharpen" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Sharpen (R)" AutomationProperties.Name="Sharpen tool" AccessKey="R">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7B3;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnSmudge" Click="Tool_Click" Tag="Smudge" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Smudge (X)" AutomationProperties.Name="Smudge tool" AccessKey="X">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7E8;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnCloneStamp" Click="Tool_Click" Tag="CloneStamp" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Clone Stamp (N) — Alt+Click to set source" AutomationProperties.Name="Clone Stamp tool" AccessKey="N">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnPatternFill" Click="Tool_Click" Tag="PatternFill" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Pattern Fill (A)" AutomationProperties.Name="Pattern Fill tool" AccessKey="A">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE771;" FontSize="14"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BtnMeasure" Click="Tool_Click" Tag="Measure" Width="30" Height="30" Padding="0" CornerRadius="4"
                                          Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Measure (W)" AutomationProperties.Name="Measure Distance tool" AccessKey="W">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9B6;" FontSize="14"/>
                            </ToggleButton>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="Tools" FontSize="10" HorizontalAlignment="Center"
                               VerticalAlignment="Bottom" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>

                <Rectangle Grid.Column="1" Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,6" VerticalAlignment="Stretch"/>

                <!-- ══ BRUSH ══ -->
                <Grid Grid.Column="2" Padding="6,4,6,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="0,0,0,4">
                        <TextBlock Text="Size" FontSize="11" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Slider x:Name="StrokeSizeSlider" Minimum="1" Maximum="50" Value="3" Width="90"
                                VerticalAlignment="Center" AutomationProperties.Name="Brush stroke size"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Style" FontSize="11" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ComboBox x:Name="BrushStyleCombo" SelectedIndex="0" Width="110" Height="30" VerticalAlignment="Center"
                                  SelectionChanged="BrushStyleCombo_SelectionChanged" FontSize="12">
                            <ComboBoxItem Content="Normal"/>
                            <ComboBoxItem Content="Calligraphy"/>
                            <ComboBoxItem Content="Airbrush"/>
                            <ComboBoxItem Content="Oil"/>
                            <ComboBoxItem Content="Crayon"/>
                            <ComboBoxItem Content="Marker"/>
                            <ComboBoxItem Content="Natural Pencil"/>
                            <ComboBoxItem Content="Watercolor"/>
                        </ComboBox>
                    </StackPanel>
                    <TextBlock Grid.Row="2" Text="Brush" FontSize="10" HorizontalAlignment="Center"
                               VerticalAlignment="Bottom" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>

                <Rectangle Grid.Column="3" Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,6" VerticalAlignment="Stretch"/>

                <!-- ══ SHAPES ══ -->
                <Grid Grid.Column="4" Padding="6,4,6,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                    </Grid.RowDefinitions>
                    <ComboBox x:Name="ShapeTypeCombo" Grid.Row="0" SelectedIndex="0" Width="130" Height="30" VerticalAlignment="Center"
                              SelectionChanged="ShapeTypeCombo_SelectionChanged" FontSize="12" Margin="0,0,0,4">
                        <ComboBoxItem Content="Rectangle"/>
                        <ComboBoxItem Content="Ellipse"/>
                        <ComboBoxItem Content="Rounded Rect"/>
                        <ComboBoxItem Content="Triangle"/>
                        <ComboBoxItem Content="Right Triangle"/>
                        <ComboBoxItem Content="Diamond"/>
                        <ComboBoxItem Content="Pentagon"/>
                        <ComboBoxItem Content="Hexagon"/>
                        <ComboBoxItem Content="Arrow"/>
                        <ComboBoxItem Content="Star"/>
                        <ComboBoxItem Content="Heart"/>
                        <ComboBoxItem Content="Lightning"/>
                    </ComboBox>
                    <ComboBox x:Name="FillModeCombo" Grid.Row="1" SelectedIndex="0" Width="130" Height="30" VerticalAlignment="Center"
                              SelectionChanged="FillModeCombo_SelectionChanged" FontSize="12">
                        <ComboBoxItem Content="Outline"/>
                        <ComboBoxItem Content="Fill"/>
                        <ComboBoxItem Content="Outline + Fill"/>
                    </ComboBox>
                    <TextBlock Grid.Row="2" Text="Shapes" FontSize="10" HorizontalAlignment="Center"
                               VerticalAlignment="Bottom" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>

                <Rectangle Grid.Column="5" Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,6" VerticalAlignment="Stretch"/>

                <!-- ══ SELECTION ══ -->
                <Grid Grid.Column="6" Padding="6,4,6,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="16"/>
                    </Grid.RowDefinitions>
                    <CheckBox x:Name="TransparentSelectionCheck" Grid.Row="0" Content="Transparent" VerticalAlignment="Center"
                              ToolTipService.ToolTip="Transparent selection (removes background color)"
                              Click="TransparentSelection_Click" FontSize="12"/>
                    <TextBlock Grid.Row="1" Text="Selection" FontSize="10" HorizontalAlignment="Center"
                               VerticalAlignment="Bottom" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>

                <Rectangle Grid.Column="7" Width="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,6" VerticalAlignment="Stretch"/>

                <!-- ══ COLORS ══ -->
                <Grid Grid.Column="8" Padding="6,2,6,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="16"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <!-- Primary / Secondary overlapping swatches -->
                        <Grid Width="36" Height="36" VerticalAlignment="Center">
                            <Border x:Name="SecondaryColorBorder" Width="22" Height="22" CornerRadius="3"
                                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}" BorderThickness="2"
                                    Background="White" Tapped="SecondaryColor_Tapped" ToolTipService.ToolTip="Secondary Color (right-click)"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                            <Border x:Name="PrimaryColorBorder" Width="22" Height="22" CornerRadius="3"
                                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}" BorderThickness="2"
                                    Background="Black" Tapped="PrimaryColor_Tapped" ToolTipService.ToolTip="Primary Color (left-click)"
                                    HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        </Grid>
                        <!-- Swap button -->
                        <Button x:Name="SwapColorsButton" Click="SwapColors_Click" ToolTipService.ToolTip="Swap Colors"
                                Width="26" Height="26" Padding="0" VerticalAlignment="Center"
                                Background="Transparent" BorderThickness="0" CornerRadius="4">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8AB;" FontSize="12"/>
                        </Button>
                        <!-- Palette grid -->
                        <GridView x:Name="ColorPaletteGrid" SelectionMode="None" IsItemClickEnabled="True"
                                  ItemClick="ColorPalette_ItemClick" VerticalAlignment="Center"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.HorizontalScrollMode="Disabled"
                                  ScrollViewer.VerticalScrollMode="Disabled">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid MaximumRowsOrColumns="2" Orientation="Vertical" ItemWidth="22" ItemHeight="22"/>
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding}" Width="18" Height="18" CornerRadius="2"
                                            BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}" BorderThickness="1"/>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="Colors" FontSize="10" HorizontalAlignment="Center"
                               VerticalAlignment="Bottom" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>

                <!-- Insert Button (SmrtPad mode) -->
                <Button x:Name="InsertButton" Grid.Column="9"
                        Click="InsertIntoDocument_Click" Visibility="Collapsed"
                        Style="{ThemeResource AccentButtonStyle}" VerticalAlignment="Center" Margin="4,0"
                        AutomationProperties.Name="Insert drawing into SmrtPad document"
                        ToolTipService.ToolTip="Insert this drawing into your SmrtPad document and close">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8DE;" FontSize="14"/>
                        <TextBlock Text="Insert into Document"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Canvas Area with ScrollViewer -->
            <ScrollViewer x:Name="CanvasScrollViewer" Grid.Column="0"
                          AutomationProperties.Name="Canvas workspace"
                          AutomationProperties.LandmarkType="Main"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          ZoomMode="Disabled" Background="{ThemeResource SolidBackgroundFillColorQuarternaryBrush}">
                <Grid x:Name="CanvasContainer" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20"
                      FlowDirection="LeftToRight">
                    <!-- Main drawing canvas -->
                    <canvas:CanvasControl x:Name="DrawingCanvas"
                                          AutomationProperties.Name="Drawing canvas"
                                          Draw="DrawingCanvas_Draw"
                                          CreateResources="DrawingCanvas_CreateResources"
                                          PointerPressed="DrawingCanvas_PointerPressed"
                                          PointerMoved="DrawingCanvas_PointerMoved"
                                          PointerReleased="DrawingCanvas_PointerReleased"
                                          AllowDrop="True"
                                          DragOver="DrawingCanvas_DragOver"
                                          Drop="DrawingCanvas_Drop"/>

                    <!-- Live text editing overlay -->
                    <TextBox x:Name="LiveTextBox"
                             Visibility="Collapsed"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Background="Transparent"
                             BorderThickness="1"
                             BorderBrush="DodgerBlue"
                             MinWidth="100"
                             MinHeight="30"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             LostFocus="LiveTextBox_LostFocus"
                             KeyDown="LiveTextBox_KeyDown"
                             AutomationProperties.Name="Live text editor"/>

                    <!-- Ruler overlay (on top of drawing canvas) -->
                    <canvas:CanvasControl x:Name="RulerCanvas" Draw="RulerCanvas_Draw"
                                          IsHitTestVisible="False"
                                          Visibility="Collapsed"/>
                </Grid>
            </ScrollViewer>

            <!-- Layer Panel -->
            <Grid Grid.Column="1" Width="220"
                  AutomationProperties.Name="Layer panel"
                  AutomationProperties.LandmarkType="Custom"
                  AutomationProperties.LocalizedLandmarkType="Layers"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header with blend mode and opacity -->
                <TextBlock Text="Layers" FontWeight="SemiBold" Margin="8,8,8,4"/>

                <Grid Grid.Row="1" Margin="6,0,6,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Blend" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <ComboBox x:Name="LayerBlendModeCombo" Grid.Column="1" Height="28" FontSize="11"
                              HorizontalAlignment="Stretch" SelectionChanged="LayerBlendMode_SelectionChanged">
                        <ComboBoxItem Content="Normal" Tag="Normal"/>
                        <ComboBoxItem Content="Dissolve" Tag="Dissolve"/>
                        <ComboBoxItem Content="Darken" Tag="Darken"/>
                        <ComboBoxItem Content="Multiply" Tag="Multiply"/>
                        <ComboBoxItem Content="Color Burn" Tag="ColorBurn"/>
                        <ComboBoxItem Content="Linear Burn" Tag="LinearBurn"/>
                        <ComboBoxItem Content="Lighten" Tag="Lighten"/>
                        <ComboBoxItem Content="Screen" Tag="Screen"/>
                        <ComboBoxItem Content="Color Dodge" Tag="ColorDodge"/>
                        <ComboBoxItem Content="Linear Dodge" Tag="LinearDodge"/>
                        <ComboBoxItem Content="Overlay" Tag="Overlay"/>
                        <ComboBoxItem Content="Soft Light" Tag="SoftLight"/>
                        <ComboBoxItem Content="Hard Light" Tag="HardLight"/>
                        <ComboBoxItem Content="Vivid Light" Tag="VividLight"/>
                        <ComboBoxItem Content="Linear Light" Tag="LinearLight"/>
                        <ComboBoxItem Content="Pin Light" Tag="PinLight"/>
                        <ComboBoxItem Content="Difference" Tag="Difference"/>
                        <ComboBoxItem Content="Exclusion" Tag="Exclusion"/>
                        <ComboBoxItem Content="Hue" Tag="Hue"/>
                        <ComboBoxItem Content="Saturation" Tag="Saturation"/>
                        <ComboBoxItem Content="Color" Tag="Color"/>
                        <ComboBoxItem Content="Luminosity" Tag="Luminosity"/>
                    </ComboBox>
                    <TextBlock Grid.Row="1" Text="Opacity" FontSize="11" VerticalAlignment="Center" Margin="0,2,4,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="LayerOpacitySlider" Minimum="0" Maximum="100" Value="100"
                                VerticalAlignment="Center" ValueChanged="LayerOpacity_ValueChanged"/>
                        <TextBlock x:Name="LayerOpacityText" Grid.Column="1" Text="100%" FontSize="11"
                                   VerticalAlignment="Center" Width="32" TextAlignment="Right"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </Grid>

                <ListView x:Name="LayerListView" Grid.Row="2" SelectionMode="Single"
                          SelectionChanged="LayerList_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="2" ColumnSpacing="4" Height="40"
                                  DoubleTapped="LayerItem_DoubleTapped"
                                  RightTapped="LayerItem_RightTapped">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Visibility checkbox -->
                                <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay}" Grid.Column="0"
                                          MinWidth="0" Padding="0" Click="LayerVisibility_Click"/>

                                <!-- Layer thumbnail -->
                                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="2"
                                        BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                        BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <Image x:Name="LayerThumbnail" Stretch="Uniform"/>
                                </Border>

                                <!-- Layer name (TextBlock for display, TextBox for editing) -->
                                <TextBlock Text="{Binding Name}" Grid.Column="2" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" FontSize="12"/>

                                <!-- Lock icon -->
                                <FontIcon Glyph="&#xE72E;" Grid.Column="3" FontSize="11"
                                          Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibility}}"
                                          VerticalAlignment="Center"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Rename Layer" Click="RenameLayer_Click">
                                <MenuFlyoutItem.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="F2"/>
                                </MenuFlyoutItem.KeyboardAccelerators>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="Toggle Lock" Click="ToggleLayerLock_Click"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="Duplicate Layer" Click="DuplicateLayer_Click"/>
                            <MenuFlyoutItem Text="Merge Down" Click="MergeDown_Click"/>
                            <MenuFlyoutItem Text="Flatten Image" Click="FlattenImage_Click"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="Delete Layer" Click="DeleteLayer_Click"/>
                        </MenuFlyout>
                    </ListView.ContextFlyout>
                </ListView>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4" Padding="4">
                    <Button Content="&#xE710;" FontFamily="Segoe MDL2 Assets" Click="AddLayer_Click"
                            ToolTipService.ToolTip="Add Layer" Width="36" Height="36"/>
                    <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Click="DeleteLayer_Click"
                            ToolTipService.ToolTip="Delete Layer" Width="36" Height="36"/>
                    <Button Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" Click="DuplicateLayer_Click"
                            ToolTipService.ToolTip="Duplicate" Width="36" Height="36"/>
                    <Button Content="&#xE74A;" FontFamily="Segoe MDL2 Assets" Click="MoveLayerUp_Click"
                            ToolTipService.ToolTip="Up" Width="36" Height="36"/>
                    <Button Content="&#xE74B;" FontFamily="Segoe MDL2 Assets" Click="MoveLayerDown_Click"
                            ToolTipService.ToolTip="Down" Width="36" Height="36"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Grid Grid.Row="3" Padding="6,2" ColumnSpacing="16"
              AutomationProperties.Name="Status bar"
              AutomationProperties.LandmarkType="Custom"
              AutomationProperties.LocalizedLandmarkType="Status"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusPosition" Grid.Column="0" Text="0, 0 px" VerticalAlignment="Center" FontSize="12"
                       AutomationProperties.Name="Cursor position" AutomationProperties.LiveSetting="Polite"/>
            <TextBlock x:Name="StatusCanvasSize" Grid.Column="1" Text="800 x 600 px" VerticalAlignment="Center" FontSize="12"
                       AutomationProperties.Name="Canvas size"/>
            <TextBlock x:Name="StatusTool" Grid.Column="2" Text="Pencil" VerticalAlignment="Center" FontSize="12"
                       AutomationProperties.Name="Active tool" AutomationProperties.LiveSetting="Assertive"/>
            <TextBlock x:Name="StatusSelection" Grid.Column="3" Text="" VerticalAlignment="Center" FontSize="12"
                       AutomationProperties.Name="Selection info" AutomationProperties.LiveSetting="Polite"/>
            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock x:Name="StatusZoom" Text="100%" VerticalAlignment="Center" FontSize="12"/>
                <Slider x:Name="ZoomSlider" Minimum="10" Maximum="800" Value="100" Width="150"
                        VerticalAlignment="Center" ValueChanged="ZoomSlider_ValueChanged" AutomationProperties.Name="Zoom level"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
